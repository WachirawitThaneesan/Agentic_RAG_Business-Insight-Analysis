# Copy this file to `.env` and fill in your own values.
# `.env` is git-ignored and must never be committed.

# --- Database (PostgreSQL + pgvector) ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5436/ragdb
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5436/ragdb

# --- Redis (Celery broker) ---
REDIS_URL=redis://localhost:6379/0

# --- Ollama (local LLM + embeddings) ---
OLLAMA_HOST=http://localhost:11434
EMBED_MODEL=nomic-embed-text:latest
OLLAMA_LLM_MODEL=qwen2.5:14b

# --- Typhoon OCR / Cloud (used for OCR and as the Ragas judge) ---
TYPHOON_API_KEY=your_key_here
TYPHOON_OCR_ENDPOINT=https://api.opentyphoon.ai/v1/ocr
TYPHOON_OCR_MODEL=typhoon-ocr

# --- Agentic RAG ---
AGENT_MAX_ITERATIONS=5
AGENT_TEMPERATURE=0.1
AGENT_SELF_CORRECTION=true
AGENT_VERIFY_MAX_RETRIES=1

# --- Knowledge Graph (Hyper-Extract) ---
HYPEREXTRACT_LLM_MODEL=qwen2.5:14b
HYPEREXTRACT_EMBED_MODEL=nomic-embed-text:latest

# --- External search (optional fallback) ---
TAVILY_API_KEY=

# --- App ---
APP_HOST=0.0.0.0
APP_PORT=8000
